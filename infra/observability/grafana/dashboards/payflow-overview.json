{
  "title": "PayFlow Overview",
  "uid": "payflow-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["payflow"],
  "panels": [
    {
      "id": 1,
      "title": "Payments by status (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (to_status) (rate(payflow_payments_transitions_total{job=\"payflow-core\"}[5m]))",
          "legendFormat": "{{to_status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Outbox backlog (PENDING rows)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "payflow_outbox_backlog{job=\"payflow-core\"}",
          "legendFormat": "backlog"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Webhook delivery outcomes (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (outcome) (rate(payflow_webhook_deliveries_total{job=\"payflow-core\"}[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Idempotency requests by result (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (result) (rate(payflow_idempotency_requests_total{job=\"payflow-core\"}[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Reconciliation sweep findings (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(payflow_reconciliation_findings_total{job=\"payflow-core\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP request latency p95 (payflow-core)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"payflow-core\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM heap used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
