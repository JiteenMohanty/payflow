# Copy this file to infra/.env and fill in real values before running
# docker compose -f infra/docker-compose.prod.yml up -d - see docs/DEPLOYMENT.md.
# infra/.env itself is gitignored; never commit real secrets.

# The domain this deployment is reachable at (used for Grafana's
# GF_SERVER_ROOT_URL so it generates correct links under the /grafana/
# subpath nginx proxies it at).
DOMAIN=payflow.example.com

# Postgres password for the payflow database user.
POSTGRES_PASSWORD=

# AES-256 key (32 raw bytes, base64-encoded) for SymmetricEncryptor -
# encrypts provider credentials and webhook secrets at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# HMAC-SHA512 signing key for JWT access/refresh tokens. Generate with:
#   openssl rand -base64 64
JWT_SECRET=

# Shared secret both payflow-core and mock-provider-service sign/verify
# inbound webhooks with (see ADR-0011, EDD section 5.4). Generate with:
#   openssl rand -hex 32
MOCK_PROVIDER_WEBHOOK_SECRET=

# Grafana's own admin account password (not the anonymous Viewer access the
# dashboard's Metrics page uses - this is for an operator who needs to edit
# dashboards or data sources directly).
GRAFANA_ADMIN_PASSWORD=
